# ─── Cuervito · environment variables ─────────────────────────────────────────
# Copy this to `.env` and fill in your values. Update src/env.js when adding new keys.

# === Node ===
NODE_ENV="development"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# === NextAuth ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# OAuth providers (optional but recommended)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# === Supabase Postgres (Prisma) ===
# DATABASE_URL: pooler (port 6543, transaction mode) — used at runtime
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate`
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# === Supabase client (only Postgres here — we use S3 for storage) ===
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# === AWS S3 (photo storage) ===
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-2"
AWS_S3_BUCKET="mediaseller-photos"
# Top-level folder inside the bucket — keeps Cuervito isolated from other apps
AWS_S3_PREFIX="cuervito"

# === Mercado Pago marketplace ===
MP_CLIENT_ID=""
MP_CLIENT_SECRET=""
MP_PUBLIC_KEY=""
MP_WEBHOOK_SECRET=""
MP_ENVIRONMENT="sandbox" # sandbox | production

# === Resend (transactional email) ===
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Cuervito <hola@cuervito.app>"

# === Platform defaults (per-photographer, overridable in DB) ===
QUOTA_STORAGE_BYTES_DEFAULT="107374182400"   # 100 GB
QUOTA_MAX_PHOTO_BYTES="31457280"             # 30 MB
QUOTA_RECOGNITION_MONTHLY_DEFAULT="10000"

# === Platform commission ===
PLATFORM_FEE_PERCENT="10" # marketplace_fee % retained on every sale
